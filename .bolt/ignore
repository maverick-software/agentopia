# =====================================================================
# .bolt/ignore — files Bolt.new should NOT load into its context
# =====================================================================
# Bolt is being used for frontend (React/Vite) development only.
# Server-side code (edge functions), DB migrations, and generated/large
# files are excluded from Bolt's view to stay within its context-window
# limits. They REMAIN in the git repo and continue to deploy via the
# Supabase CLI / normal pipeline.
# =====================================================================

# ---------------------------------------------------------------------
# Server-side: not deployable from Bolt (Supabase CLI handles these)
# ---------------------------------------------------------------------
supabase/functions/
supabase/migrations/
supabase/.temp/
supabase/config.toml
supabase/import_map.json
supabase/seed_integrations.sql

# ---------------------------------------------------------------------
# Generated / extremely large files (regenerate locally as needed)
# ---------------------------------------------------------------------
src/types/database.types.ts
package-lock.json

# ---------------------------------------------------------------------
# Database (kept in repo for reference; Bolt doesn't need)
# ---------------------------------------------------------------------
database/

# ---------------------------------------------------------------------
# Build / cache / deps
# ---------------------------------------------------------------------
node_modules/
dist/
build/
dev-dist/
.next/
out/
coverage/
.cache/
.parcel-cache/

# ---------------------------------------------------------------------
# Tests (Bolt isn't running them)
# ---------------------------------------------------------------------
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/*.spec.tsx
**/__tests__/
**/__mocks__/

# ---------------------------------------------------------------------
# Editor / VCS / OS noise
# ---------------------------------------------------------------------
.git/
.github/
.vscode/
.idea/
.DS_Store
Thumbs.db

# ---------------------------------------------------------------------
# Environment / secrets
# ---------------------------------------------------------------------
.env
.env.*
**/.env
**/.env.*

# ---------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------
*.log
logs/
logs.txt
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---------------------------------------------------------------------
# Backups (should never be committed; defense-in-depth)
# ---------------------------------------------------------------------
**/*.backup
**/*.backup_*
**/*.bak
backups/
